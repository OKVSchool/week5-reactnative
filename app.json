{
  "expo": {
    "name": "macroTrack",
    "slug": "macrotrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "macrotrack",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "plugins": [
      "expo-asset",
      "@react-native-community/datetimepicker"
    ],
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "01a076ae-b498-45dd-8fae-78b52ec9f544"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/01a076ae-b498-45dd-8fae-78b52ec9f544"
    },
    "android": {
      "package": "com.okvschool.macrotrack"
    },
    "ios": {
      "bundleIdentifier": "com.okvschool.macrotrack",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
